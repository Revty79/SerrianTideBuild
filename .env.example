DATABASE_URL=postgres://username:password@localhost:5432/serrian_tide
# Optional pool tuning
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=10000
# Set true when your provider requires SSL
DATABASE_SSL=false
# Temporary home-server HTTP testing mode only.
# Set true only when testing over plain HTTP and session cookies are not persisting.
ALLOW_INSECURE_COOKIES=false
