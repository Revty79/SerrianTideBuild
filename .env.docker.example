# --- Postgres container settings ---
POSTGRES_DB=serrian_tide
POSTGRES_USER=serrian_tide
POSTGRES_PASSWORD=change_me_strong

# --- App database connection (must point at service name "db") ---
DATABASE_URL=postgres://serrian_tide:change_me_strong@db:5432/serrian_tide
DATABASE_SSL=false

# --- Optional DB pool tuning ---
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=10000
